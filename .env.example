NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookstore
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000

# --- Railway Production ---
# NODE_ENV=production
# PORT=3000                        (Railway auto-assigns $PORT)
# DATABASE_URL=                    (Auto-injected by Railway PostgreSQL plugin)
# JWT_ACCESS_SECRET=               (Set strong random value in Railway dashboard)
# JWT_REFRESH_SECRET=              (Set strong random value in Railway dashboard)
# ALLOWED_ORIGINS=https://your-frontend.com
